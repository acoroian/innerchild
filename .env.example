# ──────────────────────────────────────────────────────────────────────────────
# aiFamily — local development env. Copy to .env and fill in.
# All production values live in GCP Secret Manager (Security review HIGH #15).
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Client-exposed Supabase. Vite only inlines VITE_-prefixed vars.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Vendor adapter selection ─────────────────────────────────────────────────
# Phase 0 default: all mocks. Flip to real vendors after Phase 0.5 bake-off.
AVATAR_ENGINE=mock
VOICE_ENGINE=mock
REPLY_LLM=mock

# ── Vendor API keys (optional — required only for chosen engines) ────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
CARTESIA_API_KEY=
TAVUS_API_KEY=
HEYGEN_API_KEY=
DID_API_KEY=

# ── Cloud Tasks / Worker (leave unset locally to run jobs in-process) ────────
CLOUD_TASKS_QUEUE=
CLOUD_TASKS_WORKER_URL=
CLOUD_TASKS_SA_EMAIL=
WORKER_SHARED_SECRET=

# ── Cloud Scheduler defense-in-depth ─────────────────────────────────────────
SCHEDULER_SHARED_SECRET=
SCHEDULER_SA_EMAIL=

# ── GCP infra (used by Makefile) ─────────────────────────────────────────────
GCP_PROJECT=
GCP_REGION=us-central1
ARTIFACT_REPO=mosaicrise
WORKER_SA=
TASKS_INVOKER_SA=
SCHEDULER_INVOKER_SA=

# ── Site / runtime ───────────────────────────────────────────────────────────
SITE_URL=http://localhost:5173
NODE_ENV=development
