{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "rootDir": "..",
    "baseUrl": "..",
    "paths": {
      "~/*": ["./app/*"]
    }
  },
  "include": ["src/**/*.ts", "../app/services/**/*.ts", "../app/lib/**/*.ts"]
}
